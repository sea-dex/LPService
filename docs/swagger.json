            "type": "object",
            "properties": {
                "code": {
                    "type": "integer",
                    "example": 200
                },
                "msg": {
                    "type": "string",
                    "example": "success"
                }
            }
        },
        "model.DCAOrder": {
            "type": "object",
            "properties": {
                "createdAt": {
                    "type": "string"
                },
                "cycleSecondsApart": {
                    "type": "integer"
                },
                "deletedAt": {
                    "type": "string"
                },
                "executedCount": {
                    "type": "integer"
                },
                "executedInAmount": {
                    "type": "number"
                },
                "expiration": {
                    "description": "timestamp at which a spender's token allowances become invalid",
                    "type": "integer"
                },
                "id": {
                    "type": "integer"
                },
                "inAmount": {
                    "description": "per time input token amount",
                    "type": "number"
                },
                "inputToken": {
                    "type": "string"
                },
                "maker": {
                    "type": "string"
                },
                "maxOutAmountPerCycle": {
                    "type": "number"
                },
                "minOutAmountPerCycle": {
                    "type": "number"
                },
                "numberOfTrade": {
                    "type": "integer"
                },
                "orderHash": {
                    "type": "string"
                },
                "outputToken": {
                    "type": "string"
                },
                "salt": {
                    "type": "integer"
                },
                "signature": {
                    "type": "string"
                },
                "status": {
                    "description": "0: new，1:booked，2:partial、3:cancelled",
                    "type": "integer"
                },
                "updatedAt": {
                    "type": "string"
                }
            }
        },
        "model.Permit": {
            "type": "object",
            "properties": {
                "amount": {
                    "description": "the maximum amount allowed to spend",
                    "type": "number"
                },
                "createdAt": {
                    "type": "string"
                },
                "deletedAt": {
                    "type": "string"
                },
                "expiration": {
                    "description": "timestamp at which a spender's token allowances become invalid",
                    "type": "integer"
                },
                "id": {
                    "type": "integer"
                },
                "nonce": {
                    "description": "an incrementing value indexed per owner,token,and spender for each signature",
                    "type": "integer"
                },
                "owner": {
                    "description": "Owner address",
                    "type": "string"
                },
                "permitHash": {
                    "type": "string"
                },
                "sigDeadline": {
                    "description": "deadline on the permit signature",
                    "type": "number"
                },
                "signature": {
                    "type": "string"
                },
                "spender": {
                    "description": "address permissioned on the allowed tokens",
                    "type": "string"
                },
                "token": {
                    "description": "ERC20 token address",
                    "type": "string"
                },
                "updatedAt": {
                    "type": "string"
                }
            }
