                    "description": "The balance of the maker",
                    "type": "integer"
                },
                "makerRate": {
                    "description": "maker rate",
                    "type": "integer"
                },
                "orderHash": {
                    "type": "string"
                },
                "orderInvalidReason": {
                    "description": "Reason for order invalidity (null or string)",
