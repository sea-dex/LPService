                },
                "inAmount": {
                    "description": "per time input token amount",
                    "type": "number"
                },
                "inputToken": {
                    "type": "string"
                },
                "maker": {
                    "type": "string"
                },
                "maxOutAmountPerCycle": {
                    "type": "number"
                },
                "minOutAmountPerCycle": {
                    "type": "number"
                },
                "numberOfTrade": {
                    "type": "integer"
                },
                "orderHash": {
                    "type": "string"
                },
                "outputToken": {
                    "type": "string"
                },
                "salt": {
                    "type": "integer"
                },
                "signature": {
                    "type": "string"
                }
            }
        },
        "param.LimitOrder": {
            "type": "object",
            "required": [
                "expiration",
                "maker",
                "makerAmount",
                "makerToken",
                "salt",
                "takerAmount",
                "takerToken"
